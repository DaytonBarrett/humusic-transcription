#include <iostream>
#include <vector>
#include <iostream>
#include <armadillo>

int matrix_operations() {
    // Create a 3x3 matrix
    arma::mat A = {{1,  1, 1},
                   {1, 1, 1},
                   {1, 1, 1}};

    // Print the matrix
    std::cout << "Matrix A:" << std::endl;
    A.print();

    // Calculate the determinant
    double detA = arma::det(A);
    std::cout << "Determinant of A: " << detA << std::endl;

    return 0;
}

int x = matrix_operations();
int * pX = &x;
 
