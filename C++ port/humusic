#include <iostream>
#include <iostream>
#include <armadillo>

int main() {
    // Create a 3x3 matrix
    arma::mat A = {{1, 1, 1},
                   {1, 1, 1},
                   {1, 1, 1}};

    // Print the matrix
    std::cout << "Matrix A:" << std::endl;
    A.print();

    // Calculate the determinant
    double detA = arma::det(A);
    std::cout << "Determinant of A: " << detA << std::endl;

    return 0;
}